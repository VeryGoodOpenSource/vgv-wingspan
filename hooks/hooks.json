{
  "description": "Wingspan hooks for development workflow automation",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "dart run ${CLAUDE_PLUGIN_ROOT}/hooks/recommend-plugins.dart",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
